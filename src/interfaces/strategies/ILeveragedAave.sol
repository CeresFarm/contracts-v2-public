    ///////////////////////////////////////////////////////////////////////////////////////////////

    event StrategyEModeUpdated(uint8 categoryId);

    ///////////////////////////////////////////////////////////////////////////////////////////////
    //                                    VIEW FUNCTIONS                                         //
    ///////////////////////////////////////////////////////////////////////////////////////////////

    function getMarketDetails() external view returns (address aavePoolAddressesProvider, address aavePool);

